{
  "description": "Wan 2.6 image-to-video generates smooth, high-quality videos from a single input image. Supports configurable video length (2-8 seconds), fps control, and motion strength tuning. API: POST JSON with {image_base64, prompt, duration_seconds, fps, motion_strength, seed} -> {video_base64, prompt, duration_s, fps, seed, wall_time_s}. GPU: requires >=16GB VRAM (RTX 4090, L40S, A6000+).",
  "type": "serverless",
  "category": "video",
  "config": {
    "runsOn": "GPU",
    "containerDiskInGb": 40,
    "gpuCount": 1,
    "gpuIds": "ADA_24,ADA_48,AMPERE_48",
    "allowedCudaVersions": [
      "12.8",
      "12.7",
      "12.6",
      "12.5",
      "12.4",
      "12.3",
      "12.2",
      "12.1",
      "12.0"
    ],
    "env": [
      {
        "key": "PYTORCH_CUDA_ALLOC_CONF",
        "value": "expandable_segments:True"
      }
    ],
    "presets": [
      {
        "name": "Fast (4s 480p)",
        "defaults": {
          "DURATION_SECONDS": "4",
          "FPS": "16",
          "HEIGHT": "480",
          "WIDTH": "832"
        }
      },
      {
        "name": "Quality (8s 720p)",
        "defaults": {
          "DURATION_SECONDS": "8",
          "FPS": "24",
          "HEIGHT": "720",
          "WIDTH": "1280"
        }
      }
    ]
  },
  "title": "elabs / Wan 2.6 I2V",
  "iconUrl": "https://pub-796a08821c1c483aaf5e274e0d03e350.r2.dev/hub-icons/wan-i2v.svg",
  "task": "image-to-video"
}